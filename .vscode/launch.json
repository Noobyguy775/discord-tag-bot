    "version": "0.2.0",
    "configurations": [
        {
            "name": "Start bot debug",
            "program": "${workspaceFolder}/source/index.js",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "type": "node"
        },
        {
            "name": "Update bot commands",
            "program": "${workspaceFolder}/source/deploy-commands.js",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "type": "node"
        },
        {
            "name": "Test DB",
            "program": "${workspaceFolder}/source/data/database.js",
            "request": "launch",
            "skipFiles": [
                "<node_internals>/**"
            ],
            "type": "node"
        }
    ]
}