name: Deploy

on:
  push:
    branches:
      - main

jobs:
  deploy:
    runs-on: ubuntu-latest
    steps:
      - name: Deploy
        run: |
          curl -X POST \
            -H "Authorization: Bearer ${{ secrets.API_KEY }}" \
            -H "Content-Type: application/json" \
            -d '{"signal": "restart"}' \
            "${{ secrets.PANEL_URL }}/api/client/servers/${{ secrets.SERVER_ID }}/power"
